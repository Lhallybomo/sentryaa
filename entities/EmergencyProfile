    "allergies": {
      "type": "string",
      "description": "Known allergies"
    },
    "medical_conditions": {
      "type": "string",
      "description": "Ongoing medical conditions"
    },
    "medications": {
      "type": "string",
      "description": "Current medications"
    },
    "next_of_kin_name": {
      "type": "string"
    },
    "next_of_kin_phone": {
      "type": "string"
    },
