{
  "name": "Hotel",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Hotel name"
    },
    "state": {
      "type": "string",
      "description": "Nigerian state"
    },
    "city": {
      "type": "string",
      "description": "City"
    },
    "address": {
      "type": "string",
      "description": "Full address"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "price_range": {
      "type": "string",
      "enum": [
        "budget",
        "mid-range",
        "luxury"
      ],
      "description": "Price category"
    },
    "price_min": {
      "type": "number",
      "description": "Minimum price per night in Naira"
    },
    "price_max": {
      "type": "number",
      "description": "Maximum price per night in Naira"
    },
    "safety_rating": {
      "type": "string",
      "enum": [
        "safe",
        "caution",
        "danger"
      ],
      "description": "Safety rating of the area"
    },
    "rating": {
      "type": "number",
      "description": "Hotel rating out of 5"
    },
    "image_url": {
      "type": "string",
      "description": "Hotel image URL"
    },
    "amenities": {
      "type": "string",
      "description": "Comma-separated amenities"
    }
  },
  "required": [
    "name",
    "state",
    "city",
    "safety_rating"
  ]
}